// 缓动函数 (Easing Functions)
float easeOutBack(float t) {
    const float c1 = 1.70158f;
    const float c3 = c1 + 1.0f;
    return 1.0f + c3 * pow(t - 1.0f, 3.0f) + c1 * pow(t - 1.0f, 2.0f);
}

float easeInOutCubic(float t) {
    return t < 0.5f ? 4.0f * t * t * t : 1.0f - pow(-2.0f * t + 2.0f, 3.0f) / 2.0f;
}

// ==========================================
// Part 1: 粒子系统 (Particle System)
// ==========================================
struct Particle {
    Vector2f pos;
    Vector2f vel;
    float life;      // 1.0 -> 0.0
    float maxLife;
    Color color;
    float size;
    float rotation;
    float rotSpeed;
};

class ParticleSystem {
private:
    list<Particle> particles;

public:
    void spawn(Vector2f pos, Color color, int count, float speed) {
        for (int i = 0; i < count; i++) {
            Particle p;
            p.pos = pos;
            float angle = (rand() % 360) * 3.14159f / 180.0f;
            float s = (rand() % 100) / 100.0f * speed;
            p.vel = Vector2f(cos(angle) * s, sin(angle) * s);
            p.life = 1.0f;
            p.maxLife = 0.5f + (rand() % 100) / 200.0f;
            p.color = color;
            p.size = 2.0f + (rand() % 5);
            p.rotation = rand() % 360;
            p.rotSpeed = (rand() % 10) - 5.0f;
            particles.push_back(p);
        }
    }

    void update() {
        for (auto it = particles.begin(); it != particles.end();) {
            it->pos += it->vel;
            it->rotation += it->rotSpeed;
            it->life -= 0.02f; // 衰减
            it->color.a = static_cast<Uint8>(it->life * 255); // 透明度渐变

            if (it->life <= 0) it = particles.erase(it);
            else ++it;
        }
    }

    void render(RenderTarget& target) {
        for (const auto& p : particles) {
            RectangleShape shape(Vector2f(p.size, p.size));
            shape.setOrigin(p.size / 2, p.size / 2);
            shape.setPosition(p.pos);
            shape.setRotation(p.rotation);
            shape.setFillColor(p.color);
            target.draw(shape, BlendAdd); // 叠加混合模式，发光效果
        }
    }
};

